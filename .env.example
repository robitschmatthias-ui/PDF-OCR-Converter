# Adobe PDF Services API credentials
# Obtain from: https://developer.adobe.com/document-services/apis/pdf-services/
#
# DO NOT commit your real .env file.
# The setup_credentials.py script stores your credentials in:
#   ~/.config/pdf-ocr-converter/.env  (Linux)
#   %APPDATA%\pdf-ocr-converter\.env  (Windows)

PDF_SERVICES_CLIENT_ID=your-client-id-here
PDF_SERVICES_CLIENT_SECRET=your-client-secret-here

# Default OCR language (see docs/adobe-credentials.md for supported locales)
OCR_DEFAULT_LOCALE=de-de
